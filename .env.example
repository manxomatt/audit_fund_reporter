# Copy this file to `.env` and fill in your own key.
#   cp .env.example .env
#
# The LLM narrative layer is OPT-IN. The system runs fully offline without a
# key; this is only needed for `python run.py --llm` (or `--both --llm`).
# `.env` is git-ignored so your key is never committed.
ANTHROPIC_API_KEY=
